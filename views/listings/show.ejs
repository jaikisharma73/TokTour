<% layout("/layouts/boilerplate")%>

  <div class="row mt-4">
    <div class="col-10 offset-1">
      <h3 class="mb-4">
        <%=listing.title %>
      </h3>
      <div class="card show-cards form-wrapper" style="padding: 1.5rem;">
        <div class="row g-0">
          <div class="col-md-5 pe-md-4 mb-4 mb-md-0">
            <img src="<%=listing.image.url%>" class="img-fluid rounded show-img w-100" alt="Listing Image" />
          </div>
          <div class="col-md-7">
            <div class="card-body ps-md-4">
              <h2 class="card-title" style="color: black; font-weight: 700; margin-bottom: 1rem;">
                <%=listing.title %>
              </h2>
              <p class="card-text text-muted" style="font-size: 1.1rem; line-height: 1.6;">
                <%= listing.description %>
              </p>

              <ul class="list-unstyled mt-4" style="font-size: 1.1rem;">
                <li class="mb-3">
                  <i class="fa-solid fa-indian-rupee-sign me-2"></i> <strong>Price:</strong> &#8377; <%= (listing.price
                    !==null && listing.price !==undefined) ? listing.price.toLocaleString("en-IN") : "N/A" %> /night
                </li>
                <li class="mb-3"><i class="fa-solid fa-location-dot me-2"></i> <strong>Location:</strong>
                  <%= listing.location %>
                </li>
                <li class="mb-3"><i class="fa-solid fa-globe me-2"></i> <strong>Country:</strong>
                  <%= listing.country %>
                </li>
              </ul>

              <div class="btns mt-4 pt-2 border-top">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger me-3"
                  style="padding: 0.5rem 1.5rem;">Edit</a>
                <form method="post" action="/listings/<%=listing._id%>?_method=DELETE" style="display:inline;">
                  <button class="btn btn-dark" style="padding: 0.5rem 1.5rem;">Delete</button>
                </form>
              </div>
              <hr class="mt-4 mb-4">
              <div class="col-12 mt-4">
                <h4 class="mb-3" style="font-weight: 700;">Leave a Review</h4>
                <form action="/listings/<%= listing._id %>/reviews" method="POST" class="p-4 border rounded shadow-sm"
                  style="background-color: #fafafa; border-color: #e9ecef;">
                  <div class="mb-3">
                    <label for="rating" class="form-label" style="font-weight: 600;">Rating</label>
                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
                  </div>
                  <div class="mb-3">
                    <label for="comment" class="form-label" style="font-weight: 600;">Comments</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control"
                      style="resize: none;" required></textarea>
                  </div>
                  <button class="btn btn-dark mt-2 fw-semibold"
                    style="border-radius: 0.5rem; padding: 0.5rem 1.5rem;">Submit</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>